// 4. GET /api/pedidos?fecha=... -> fetch orders filterable by date
app.get('/api/pedidos', (req, res) => {
  try {
    const { fecha } = req.query;
    let query = 'SELECT p.*, c.nombre as cliente_nombre FROM pedidos p JOIN clientes c ON p.cliente_id = c.id';
    let params: any[] = [];
    
    if (fecha) {
      query += ' WHERE p.fecha = ?';
      params.push(fecha);
    }
    
    query += ' ORDER BY p.id DESC';
    const rows = db.prepare(query).all(...params);

    // Hydrate each order with their order details
    const hydratedRows = rows.map((order: any) => {
      const items = db.prepare(`
        SELECT dp.*, prod.nombre, prod.imagen_url 
        FROM detalle_pedidos dp 
        JOIN productos prod ON dp.producto_id = prod.id 
        WHERE dp.pedido_id = ?
      `).all(order.id);
      return { ...order, items };
    });

    res.json(hydratedRows);
  } catch (error) {
    res.status(500).json({ error: 'Error al cargar pedidos' });
  }
});

// 5. POST /api/pedidos -> place a new delivery txn
app.post('/api/pedidos', (req, res) => {
  try {
    const { cliente_id, productos, zona, direccion, ref_direccion, metodo_pago } = req.body;
    
    if (!cliente_id || !productos || productos.length === 0) {
      return res.status(400).json({ error: 'Campos requeridos incompletos' });
    }

    const todayStr = new Date().toISOString().split('T')[0];
    const timeStr = new Date().toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit', hour12: false });
    const tracking = 'RS-' + Math.floor(1000 + Math.random() * 9000);

    // Calculate totals
    let subtotal = 0;
    for (const item of productos) {
      const prod = db.prepare('SELECT precio FROM productos WHERE id = ?').get(item.id);
      if (prod) {
        subtotal += (prod as any).precio * item.cantidad;
      }
    }
    const cost_envio = 1500;
    const total = subtotal + cost_envio;

    // Insert order transactionally
    const stmt = db.prepare(`
      INSERT INTO pedidos (tracking_number, cliente_id, repartidor_id, estado, zona, direccion, subtotal, costo_envio, total, fecha, hora, metodo_pago, ref_direccion)
      VALUES (?, ?, 1, 'Preparación', ?, ?, ?, ?, ?, ?, ?, ?, ?)
    `);
    
    const result = stmt.run(tracking, cliente_id, zona, direccion, subtotal, cost_envio, total, todayStr, timeStr, metodo_pago || 'Crédito Webpay', ref_direccion || '');
    const newOrderId = result.lastInsertRowid;

    // Detallar productos
    for (const item of productos) {
      const prod = db.prepare('SELECT precio FROM productos WHERE id = ?').get(item.id);
      const price = prod ? (prod as any).precio : 0;
      db.prepare(`
        INSERT INTO detalle_pedidos (pedido_id, producto_id, cantidad, precio)
        VALUES (?, ?, ?, ?)
      `).run(newOrderId, item.id, item.cantidad, price);
    }

    // Insert default receiving notification
    db.prepare(`
      INSERT INTO notificaciones (cliente_id, pedido_id, mensaje, leido, fecha)
      VALUES (?, ?, ?, 0, ?)
    `).run(cliente_id, newOrderId, 'Tu pedido está siendo preparado.', todayStr);

    const fullOrder = {
      id: newOrderId,
      tracking_number: tracking,
      cliente_id,
      estado: 'Preparación',
      zona,
      direccion,
      total,
      fecha: todayStr,
      hora: timeStr
    };

    broadcastUpdate({ type: 'NEW_ORDER', order: fullOrder });
    res.status(201).json(fullOrder);
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Error al registrar pedido' });
  }
});

// 6. PATCH /api/pedidos/:id/estado -> change delivery state
app.patch('/api/pedidos/:id/estado', (req, res) => {
  try {
    const { id } = req.params;
    const { estado } = req.body; // e.g. "PREPARANDO", "ASIGNADO", "MATIAS_ACEPTO", "EN_CAMINO", "ENTREGADO", "PROXIMO_5_MIN"

    if (!estado) {
      return res.status(400).json({ error: 'Estado requerido' });
    }

    // Grab current info
    const currentOrder = db.prepare('SELECT * FROM pedidos WHERE id = ?').get(id) as any;
    if (!currentOrder) {
      return res.status(404).json({ error: 'Pedido no encontrado' });
    }

    // Map stages to Spanish client notification updates explicitly
    let notificationText = '';
    const upperCap = estado.toUpperCase();
    if (upperCap === 'PREPARACION' || upperCap === 'PREPARACIÓN' || upperCap === 'PREPARANDO') {
      notificationText = 'Tu pedido está siendo preparado.';
    } else if (upperCap === 'ENTREGADO AL REPARTIDOR' || upperCap === 'ENTREGADO_AL_REPARTIDOR' || upperCap === 'MATIAS_ACEPTO' || upperCap === 'ASIGNADO') {
      const clientRow = db.prepare('SELECT nombre FROM clientes WHERE id = ?').get(currentOrder.cliente_id) as any;
      const clientName = clientRow ? clientRow.nombre : 'Julián Cortés';
      notificationText = `Matías aceptó el pedido de ${clientName}.`;
    } else if (upperCap === 'EN_CAMINO') {
      notificationText = 'Tu pedido está en camino.';
    } else if (upperCap === 'PROXIMO_5_MIN') {
      notificationText = 'Tu repartidor llegará en aproximadamente 5 minutos.';
    } else if (upperCap === 'ENTREGADO') {
      notificationText = 'Tu pedido fue entregado correctamente.';
    } else {
      notificationText = `Estado del pedido cambiado a ${estado}.`;
    }

    // Update order status
    db.prepare('UPDATE pedidos SET estado = ? WHERE id = ?').run(estado, id);

    // Save notification
    const todayStr = new Date().toISOString().split('T')[0];
    db.prepare(`
      INSERT INTO notificaciones (cliente_id, pedido_id, mensaje, leido, fecha)
      VALUES (?, ?, ?, 0, ?)
    `).run(currentOrder.cliente_id, id, notificationText, todayStr);

    broadcastUpdate({ type: 'ORDER_STATE_CHANGED', orderId: id, estado: estado, notification: notificationText });

    res.json({ success: true, estado: estado, notification: notificationText });
  } catch (error) {
    console.error(error);
    res.status(500).json({ error: 'Error al cambiar estado' });
  }
});

// 7. GET /api/ruta/hoy -> optimized route of the day
app.get('/api/ruta/hoy', (req, res) => {
  try {
    // Generate optimized delivery routing list. Active orders that are 'EN_CAMINO' or 'PENDIENTE'
    const activeOrders = db.prepare(`
      SELECT p.*, c.nombre as cliente_nombre 
      FROM pedidos p 
      JOIN clientes c ON p.cliente_id = c.id
      WHERE p.estado IN ('PENDIENTE', 'EN_RUTA', 'ASIGNADO', 'MATIAS_ACEPTO', 'EN_CAMINO')
      ORDER BY p.id ASC
    `).all();

    res.json({
      repartidor: 'Matías Aravena',
      vehiculo: 'Bicicleta',
      total_paradas: activeOrders.length,
      ruta_optimizada: activeOrders
    });
  } catch (error) {
    res.status(500).json({ error: 'Error al calcular optimización de ruta' });
  }
});

