// Authentication routes
app.post('/api/auth/login', (req, res) => {
  try {
    const { correo, contraseña } = req.body;
    if (!correo || !contraseña) {
      return res.status(400).json({ error: 'Correo/Usuario y contraseña vacíos' });
    }

    // Try finding by correo, email or nombre
    const client = db.prepare('SELECT * FROM clientes').all().find((c: any) => 
      (c.correo && c.correo.toLowerCase() === correo.toLowerCase()) ||
      (c.email && c.email.toLowerCase() === correo.toLowerCase()) ||
      (c.nombre && c.nombre.toLowerCase() === correo.toLowerCase())
    );

    if (!client) {
      return res.status(401).json({ error: 'Credenciales inválidas o cliente no encontrado.' });
    }

    if (!client.contraseña_hash || client.contraseña_hash !== contraseña) {
      return res.status(401).json({ error: 'Contraseña incorrecta.' });
    }

    // Register active session in sesiones
    const token = 'sess_' + Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
    const dateStart = new Date().toISOString();
    const id_cliente = client.id_cliente || client.id;
    
    db.prepare(`
      INSERT INTO sesiones (id_cliente, token_sesion, fecha_inicio, fecha_cierre)
      VALUES (?, ?, ?, NULL)
    `).run(id_cliente, token, dateStart);

    res.json({
      success: true,
      mensaje: `Bienvenido, ${client.nombre}`,
      token_sesion: token,
      cliente: {
        id: client.id,
        id_cliente: id_cliente,
        nombre: client.nombre,
        email: client.email,
        correo: client.correo || client.email,
        telefono: client.telefono,
        nivel: client.nivel,
        zona: client.zona,
        foto_url: client.foto_url
      }
    });
  } catch (error) {
    console.error('Error en login:', error);
    res.status(500).json({ error: 'Error del servidor en el inicio de sesión' });
  }
});

app.post('/api/auth/logout', (req, res) => {
  try {
    const { token_sesion } = req.body;
    if (!token_sesion) {
      return res.status(400).json({ error: 'Token de sesión requerido para cerrar sesión' });
    }

    const dateEnd = new Date().toISOString();
    db.prepare(`
      UPDATE sesiones 
      SET fecha_cierre = ? 
      WHERE token_sesion = ?
    `).run(dateEnd, token_sesion);

    res.json({
      success: true,
      mensaje: 'Has cerrado sesión correctamente.'
    });
  } catch (error) {
    console.error('Error en logout:', error);
    res.status(500).json({ error: 'Error del servidor en el cierre de sesión' });
  }
});

