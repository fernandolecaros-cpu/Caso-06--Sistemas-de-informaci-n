// Simple Server-Sent Events (SSE) notification stream for push updates
let clientResConnections: any[] = [];

app.get('/api/updates', (req, res) => {
  res.setHeader('Content-Type', 'text/event-stream');
  res.setHeader('Cache-Control', 'no-cache');
  res.setHeader('Connection', 'keep-alive');
  res.flushHeaders();

  clientResConnections.push(res);

  req.on('close', () => {
    clientResConnections = clientResConnections.filter(c => c !== res);
  });
});

function broadcastUpdate(data: any) {
  clientResConnections.forEach(res => {
    res.write(`data: ${JSON.stringify(data)}\n\n`);
  });
}

